# Open DART: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
DART_API_KEY=

# SEC는 키 대신 식별 가능한 앱/담당자 정보를 User-Agent에 요구합니다.
# 예: Longview Screener admin@example.com
SEC_USER_AGENT=

# 금융위원회 주식시세정보(T+1 종가) 활용신청 후 받은 일반 인증키(Decoding)를 넣습니다.
# https://www.data.go.kr/data/15094808/openapi.do
DATA_GO_KR_API_KEY=

# 공개 재배포 권리를 별도로 보유한 미국 시세 JSON snapshot이 있을 때만 사용합니다.
US_LICENSED_PRICE_SNAPSHOT_URL=
US_LICENSED_PRICE_SNAPSHOT_TOKEN=
# 위 URL과 manifest 출처에 허용할 host를 쉼표로 적습니다. 예: prices.example.com
US_LICENSED_PRICE_ALLOWED_HOSTS=

# GitHub Actions가 갱신한 공개 data/companies.json 원본 주소(선택)
# 설정하면 npm start 때 즉시 확인하고 .cache에서 30분마다 자동 갱신합니다.
# 예: https://raw.githubusercontent.com/USER/REPO/main/data/companies.json
REMOTE_SNAPSHOT_URL=

# 비공개 저장소는 별도 배포 구성이 필요합니다. 공개 raw 주소라면 비워 둡니다.
REMOTE_SNAPSHOT_TOKEN=

# 서버
PORT=4173
HOST=127.0.0.1

# REMOTE_SNAPSHOT_URL 없이 이 컴퓨터가 직접 전체수집할 때만 true
ENABLE_SCHEDULER=false
# 위 로컬 전체수집 시각
SCHEDULE_HOUR_KST=21

# 수동 동기화 API 보호용. 설정하지 않으면 POST /api/sync 비활성화
SYNC_TOKEN=
