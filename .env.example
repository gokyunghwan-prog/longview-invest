# Open DART: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
DART_API_KEY=

# 금융위원회 주식시세정보(T+1 종가) 활용신청 후 받은 일반 인증키(Decoding)를 넣습니다.
# https://www.data.go.kr/data/15094808/openapi.do
DATA_GO_KR_API_KEY=

# GitHub Actions가 갱신한 공개 data/companies.json 원본 주소(선택)
# 설정하면 npm start 때 즉시 확인하고 .cache에서 30분마다 자동 갱신합니다.
# 예: https://raw.githubusercontent.com/USER/REPO/main/data/companies.json
REMOTE_SNAPSHOT_URL=
# 비워두면 REMOTE_SNAPSHOT_URL의 같은 data 폴더에서 자동으로 찾습니다.
REMOTE_INVESTMENT_SELECTION_URL=

# 비공개 저장소는 별도 배포 구성이 필요합니다. 공개 raw 주소라면 비워 둡니다.
REMOTE_SNAPSHOT_TOKEN=

# 서버
PORT=4173
HOST=127.0.0.1

# REMOTE_SNAPSHOT_URL 없이 이 컴퓨터가 직접 전체수집할 때만 true
ENABLE_SCHEDULER=false
# 위 로컬 전체수집 시각
SCHEDULE_HOUR_KST=21

# 수동 동기화 API 보호용. 설정하지 않으면 POST /api/sync 비활성화
SYNC_TOKEN=

# ---------------------------------------------------------------------------
# 별도 자동매매 서비스 (기본값은 완전 비활성)
# 기존 웹사이트와 다른 4180 포트를 사용하며, 실제 주문은 아래 값을 직접 바꾸기 전까지
# 절대로 전송하지 않습니다. 키와 계좌번호는 채팅·GitHub에 올리지 마세요.
TRADING_MODE=disabled
TRADING_BROKER=paper
TRADING_HOST=127.0.0.1
TRADING_PORT=4180
LONGVIEW_BASE_URL=http://127.0.0.1:4173
LONGVIEW_TIMEOUT_MS=10000
TRADING_REQUIRE_PUBLISHED_SELECTION=true

# Longview 국내 가치·장기 자동투자 기본 안전선
TRADING_APPROVED_MODEL_VERSION=2.0.0
TRADING_MIN_SCORE=78
TRADING_MIN_CONFIDENCE=85
TRADING_MIN_COMPLETENESS=85
TRADING_MIN_VALUATION_CONFIDENCE=75
TRADING_MIN_POSITIONS=3
TRADING_MAX_POSITIONS=5
# 목표 현금은 0%입니다. 다만 1주 단위·수수료·지정가 때문에 소액 잔액은 남을 수 있습니다.
TRADING_CASH_RESERVE_PERCENT=0
TRADING_MAX_POSITION_PERCENT=35
TRADING_MAX_SECTOR_PERCENT=35
TRADING_MIN_MARKET_CAP_KRW=100000000000
TRADING_MIN_DAILY_TURNOVER_KRW=500000000
TRADING_MIN_POSITION_KRW=20000
TRADING_MIN_ORDER_KRW=5000
# 매일 새 스냅샷을 평가하되 비중 이탈·확정 악화·더 우수한 후보가 있을 때만 거래합니다.
TRADING_REBALANCE_FREQUENCY=daily
TRADING_REBALANCE_DRIFT_PERCENT=3
TRADING_REMOVAL_CONFIRMATIONS=2
# 보유종목에는 이 점수만큼 유지 가산점을 주어 작은 순위 변동에 매매하지 않습니다.
TRADING_REPLACEMENT_SCORE_LEAD=3
# 최초 배치는 가용자금의 최대 100%, 이후 조정은 아래의 낮은 회전율 한도를 적용합니다.
TRADING_INITIAL_DEPLOYMENT_TURNOVER_PERCENT=100
TRADING_MAX_TURNOVER_PERCENT=20
# true이면 이후 입금된 시작 시점 가용현금도 기존 교체·분산 안전규칙 안에서 자동 배치합니다.
# 실전에서는 현금 0%, 상한 0원, 전용계좌 전체자산 잠금 해제가 모두 필요합니다.
TRADING_AUTODEPLOY_CASH=false
TRADING_MAX_ORDERS_PER_RUN=10
TRADING_LIMIT_BUFFER_PERCENT=0.5
TRADING_MAX_SIGNAL_PRICE_DEVIATION_PERCENT=10
# 양수면 자동투자 원금·수익을 합친 관리자산의 원화 상한입니다.
# 0은 아래 전용계좌 전체자산 잠금을 모두 해제한 실전 설정에서만 허용됩니다.
TRADING_CAPITAL_LIMIT_KRW=0
TRADING_REQUIRE_DEDICATED_ACCOUNT=true
TRADING_USE_ALL_DEDICATED_ACCOUNT_ASSETS=false
USE_ALL_DEDICATED_ACCOUNT_ASSETS_ACK=
TRADING_MAX_SNAPSHOT_AGE_DAYS=3
TRADING_MAX_PRICE_AGE_DAYS=10

# 로컬 모의투자 원장
PAPER_STARTING_CASH_KRW=100000
PAPER_FEE_PERCENT=0.02

# 한국투자 Open API: App Key·App Secret과 계좌번호 앞 8자리·상품코드 뒤 2자리가 필요합니다.
# 먼저 모의(vps) 값으로 검증하고 실전 값은 GitHub나 채팅에 올리지 마세요.
KIS_ENV=vps
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=

# 실전 이중 잠금. 모의 검증 전에는 아래 두 값을 절대 변경하지 않습니다.
ENABLE_LIVE_TRADING=false
LIVE_TRADING_ACK=

# 자동 실행은 기본 꺼짐. 처음에는 paper 모드에서만 사용하세요.
TRADING_AUTORUN_ENABLED=false
TRADING_AUTORUN_HOUR_KST=9
TRADING_AUTORUN_MINUTE_KST=23
ENABLE_UNATTENDED_LIVE_TRADING=false
UNATTENDED_LIVE_TRADING_ACK=

# GitHub Actions 실전 상태 암호화용(32바이트 표준 Base64). 평문을 커밋하지 않습니다.
AUTOTRADE_STATE_KEY=
CLOUD_LIVE_TRADING_ACK=
