# Open DART: https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do
DART_API_KEY=

# SEC는 키 대신 식별 가능한 앱/담당자 정보를 User-Agent에 요구합니다.
# 예: Longview Screener admin@example.com
SEC_USER_AGENT=

# GitHub Actions가 갱신한 공개 data/companies.json 원본 주소(선택)
# 예: https://raw.githubusercontent.com/USER/REPO/main/data/companies.json
REMOTE_SNAPSHOT_URL=

# 비공개 저장소는 별도 배포 구성이 필요합니다. 공개 raw 주소라면 비워 둡니다.
REMOTE_SNAPSHOT_TOKEN=

# 서버
PORT=4173
HOST=127.0.0.1

# 서버 자체 일일 스케줄러를 켤 때만 true (기본 실행 시 중복 갱신 방지)
ENABLE_SCHEDULER=false
# GitHub Actions(19:35 KST) 완료 뒤 미국 스냅샷도 받도록 21시 권장
SCHEDULE_HOUR_KST=21

# 수동 동기화 API 보호용. 설정하지 않으면 POST /api/sync 비활성화
SYNC_TOKEN=
